{
  "name": "media-converter-lab",
  "version": "1.0.0",
  "description": "A desktop-first local media converter for video, audio and image conversion.",
  "author": "FakecaptainYan",
  "main": "desktop/electron-main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:web": "node server.js",
    "start:desktop": "node scripts/start-electron.js",
    "dist": "node scripts/package-desktop.js",
    "dist:win": "node scripts/package-desktop.js win",
    "dist:mac": "node scripts/package-desktop.js mac"
  },
  "build": {
    "appId": "com.fakecaptainyan.media-converter-lab",
    "productName": "Media Converter Lab",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app-server.js",
      "desktop/**/*",
      "media-core.js",
      "public/**/*",
      "scripts/**/*",
      "server.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "license": "MIT"
}
