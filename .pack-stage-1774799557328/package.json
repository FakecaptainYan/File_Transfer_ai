{
  "name": "apple-media-converter",
  "version": "1.0.0",
  "description": "A desktop-first local media converter with Apple-inspired UI for video, audio and image conversion.",
  "main": "desktop/electron-main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:web": "node server.js",
    "start:desktop": "node scripts/start-electron.js",
    "dist:win": "node scripts/package-desktop.js"
  },
  "build": {
    "appId": "com.codex.apple-media-converter",
    "productName": "Apple Media Converter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app-server.js",
      "desktop/**/*",
      "media-core.js",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "license": "MIT"
}
